<mxfile host="app.diagrams.net" modified="2026-05-19T12:00:00.000Z" agent="Kiro" version="24.0.0" type="device">
  <diagram id="app-restricted-flow" name="Application-Restricted Auth Flow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Application-Restricted Authentication Flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="30" as="geometry" />
        </mxCell>
        <!-- Participants -->
        <mxCell id="client-box" value="Client Application&#xa;(e.g. BaRS Proxy,&#xa;Supplier Backend)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="apim-box" value="NHS England API Platform&#xa;(APIM / OAuth Token Endpoint)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="70" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="epc-box" value="Endpoint Catalog API&#xa;(Lambda)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="70" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- Lifelines -->
        <mxCell id="client-line" style="endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="130" as="sourcePoint" />
            <mxPoint x="160" y="620" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="apim-line" style="endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="130" as="sourcePoint" />
            <mxPoint x="550" y="620" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="epc-line" style="endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="960" y="130" as="sourcePoint" />
            <mxPoint x="960" y="620" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 1: Client constructs JWT -->
        <mxCell id="step1-note" value="1. Construct signed JWT&#xa;(client_id, exp, jti,&#xa;signed with private key)" style="shape=note;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="150" width="180" height="50" as="geometry" />
        </mxCell>
        <!-- Step 2: Token request -->
        <mxCell id="step2" value="2. POST /oauth2/token&#xa;grant_type=client_credentials&#xa;client_assertion=&lt;signed JWT&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="220" as="sourcePoint" />
            <mxPoint x="550" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 3: APIM validates -->
        <mxCell id="step3-note" value="3. APIM validates JWT:&#xa;- Extract kid from header&#xa;- Fetch client JWKS&#xa;- Verify signature" style="shape=note;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="430" y="240" width="170" height="60" as="geometry" />
        </mxCell>
        <!-- Step 4: Token returned -->
        <mxCell id="step4" value="4. 200 OK&#xa;{ access_token: &quot;token-for-epc&quot;, expires_in: 300 }" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="320" as="sourcePoint" />
            <mxPoint x="160" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 5: API call -->
        <mxCell id="step5" value="5. GET /Endpoint?...&#xa;Authorization: Bearer token-for-epc&#xa;NHSD-End-User-Organisation-ODS: R1X" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="380" as="sourcePoint" />
            <mxPoint x="960" y="380" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 6: EPC validates -->
        <mxCell id="step6-note" value="6. Validate token&#xa;Extract ODS from claims&#xa;Compare with header&#xa;Check ownership (if write)" style="shape=note;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="860" y="400" width="170" height="60" as="geometry" />
        </mxCell>
        <!-- Step 7: Response -->
        <mxCell id="step7" value="7. 200 OK (response)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="960" y="490" as="sourcePoint" />
            <mxPoint x="160" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Alt: 403 -->
        <mxCell id="step7-alt" value="OR 403 Forbidden (ODS mismatch / ownership failure)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;fontSize=9;strokeColor=#cc0000;fontColor=#cc0000;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="960" y="530" as="sourcePoint" />
            <mxPoint x="160" y="530" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
